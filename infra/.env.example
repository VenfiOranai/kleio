# Copy to infra/.env on the server and fill in real values. infra/.env is gitignored.
# Consumed by docker-compose.prod.yml.

# Database
POSTGRES_USER=kleio
POSTGRES_PASSWORD=            # strong random password
POSTGRES_DB=kleio

# Single-user auth (generate the hash with oracle/scripts/hash_password.py)
APP_USERNAME=changeme
APP_PASSWORD_HASH=            # bcrypt hash — wrap in single quotes if it contains $
JWT_SECRET=                   # long random string, e.g. `openssl rand -hex 32`
JWT_EXPIRE_MINUTES=1440

# AI (Gemini) — summarization + RAG Q&A. Without a key, those endpoints return 503.
GEMINI_API_KEY=              # Google AI Studio API key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_EMBED_MODEL=gemini-embedding-001
