# Copy to .env and fill in real values. .env is gitignored — never commit secrets.

# ---- Oracle (backend) ----
# Single-user auth. Generate the hash with the project helper (Phase 0) — do NOT
# store the plaintext password here.
APP_USERNAME=changeme
APP_PASSWORD_HASH=            # bcrypt hash of your password
JWT_SECRET=                   # long random string, e.g. `openssl rand -hex 32`
JWT_EXPIRE_MINUTES=1440

# Database (matches infra/docker-compose.yml service name in dev)
DATABASE_URL=postgresql+psycopg://kleio:kleio@localhost:5432/kleio
POSTGRES_USER=kleio
POSTGRES_PASSWORD=kleio
POSTGRES_DB=kleio

# ---- AI (added at the summarization / Q&A phases) ----
GEMINI_API_KEY=

# ---- Herald (frontend) ----
# API base path; nginx proxies /api in prod so this is usually just "/api".
API_BASE_URL=/api
